<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f4f7f6"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    tools:context=".InstructionsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#5BC6D1"
            android:padding="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BookFlow: לנהל את מסע הקריאה שלך"
                android:textColor="@color/black"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מעקב ספרים מקיף, חכם וחברתי – מכל מקום, בכל זמן."
                android:textColor="@color/black"
                android:textSize="16sp"
                android:gravity="center"/>

            <Button
                android:id="@+id/btn_cta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="התחל עכשיו!"
                android:backgroundTint="#e74c3c"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"
                android:layout_marginTop="20dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFBF0">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#E0FFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📚 התכונות המרכזיות"
                        android:textColor="#e74c3c"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="15dp"/>

                    <LinearLayout
                        style="@style/FeatureItemRow"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="מעקב התקדמות קל"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="right"
                            android:textColor="#2c3e50"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="עדכון מספר העמודים שנקראו בלחיצה, וקבלת תצוגה גרפית של ההתקדמות שלך."
                            android:textSize="16sp"
                            android:textColor="#333"
                            android:layout_marginRight="10dp"/>
                    </LinearLayout>
                    <View style="@style/Divider" />

                    <LinearLayout
                        style="@style/FeatureItemRow"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ספרייה אישית חכמה"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="right"
                            android:textColor="#2c3e50"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="הוספת ספרים חדשים עם כל הפרטים הרלוונטיים (כותר, מחבר, ז'אנר ועוד)."
                            android:textSize="16sp"
                            android:textColor="#333"
                            android:layout_marginRight="10dp"/>
                    </LinearLayout>
                    <View style="@style/Divider" />

                    <LinearLayout
                        style="@style/FeatureItemRow"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="קהילת קוראים חברתית"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="right"
                            android:textColor="#2c3e50"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="פרסום דירוגים ותגובות לאחר סיום ספר, ושיתוף מיידי בפורום קוראים."
                            android:textSize="16sp"
                            android:textColor="#333"
                            android:layout_marginRight="10dp"/>
                    </LinearLayout>
                    <View style="@style/Divider" />

                    <LinearLayout
                        style="@style/FeatureItemRow"
                        android:layout_marginBottom="0dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="כוחה של הבינה המלאכותית (AI)"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="right"
                            android:textColor="#2c3e50"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="קבל המלצות קריאה מותאמות אישית ומידע מעניין על ספרים ישנים וחדשים."
                            android:textSize="16sp"
                            android:textColor="#333"
                            android:layout_marginRight="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#E0FFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚀 איך זה עובד?"
                        android:textColor="#e74c3c"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="15dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. כניסה מאובטחת: התחילו בתהליך הרשמה וכניסה מהיר ומאובטח."
                        android:layout_marginBottom="8dp"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. הוספת ספר: הוסיפו את הספר הנוכחי שלכם לספרייה האישית."
                        android:layout_marginBottom="8dp"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. עדכון התקדמות: עדכנו בקלות את מספר העמודים שקראתם."
                        android:layout_marginBottom="8dp"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4. סיום ודירוג: סיימתם? דרגו והוסיפו תגובה – הדירוג מתפרסם בקהילה!"
                        android:layout_marginBottom="8dp"
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#E0FFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏰ תזכורות קריאה"
                        android:textColor="#e74c3c"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="15dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="שומרים על רצף הקריאה! דרך מסך ההגדרות תוכלו להפעיל תזכורת יומית חכמה (למשל ב-10:00 בבוקר). המערכת תשלח לכם התראה לטלפון ותוודא שלא תשכחו לחזור לעלילה של הספר שלכם."
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#E0FFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 גלו את הלא נודע עם AI"
                        android:textColor="#e74c3c"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="15dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="עמוד הבינה המלאכותית שלנו הוא כלי הגילוי האולטימטיבי. בין אם אתם מחפשים המלצה לספר הבא שמותאם לטעם האישי שלכם, או שאתם רוצים ללמוד עובדות מעניינות על הספר שאתם קוראים עכשיו – ה-AI של BookFlow כאן בשבילכם."
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>